      ],
      "mobileEffects": "static"
    },
    "agd-days": {
      "decorations": [
        "home-line",
        "kitchen-badge"
      ],
      "mobileEffects": "static"
    }
  },
  "studioChecklist": [
    "Dodaj media",
    "Ustaw ALT",
    "Wybierz użycia",
    "Sprawdź desktop",
    "Sprawdź mobile",
